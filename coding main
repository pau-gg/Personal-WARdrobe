function item(name, color, category, formal, seasons, extra = {}) {
  return {
    id: `${category}-${name}`.toLowerCase().replace(/[^a-z0-9]+/g, "-"),
    name,
    color,
    category,
    formal,
    seasons,
    ...extra
  };
}

