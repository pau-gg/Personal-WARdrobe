            <div className="mt-5 rounded-[1.5rem] bg-white p-4 ring-1 ring-purple-100">
              <h3 className="font-black text-[#2a2040]">Bestand erweitern</h3>
              <div className="mt-3 grid gap-2">
               <select value={newItem.group}
                onChange={(e) => setNewItem((p) => ({ ...p,
                group: e.target.value
            }))
}                                              
className="rounded-2xl border border-purple-100 bg-white text-slate-800 px-3 py-2 text-sm"
>
                  <option value="blazers">Blazer</option><option value="pants">Hose</option><option value="tops">Top</option><option value="coats">Mantel</option><option value="shoes">Schuhe</option><option value="belts">Gürtel</option>
                </select>
                <input value={newItem.name} onChange={(e) => setNewItem((p) => ({ ...p, name: e.target.value }))} placeholder="Name" className="rounded-2xl border border-purple-100 px-3 py-2 text-sm" />
                <div className="grid grid-cols-2 gap-2">
                  <input value={newItem.color} onChange={(e) => setNewItem((p) => ({ ...p, color: e.target.value }))} placeholder="Farbe" className="rounded-2xl border border-purple-100 px-3 py-2 text-sm" />
                  <input type="number" min="1" max="10" value={newItem.formal} onChange={(e) => setNewItem((p) => ({ ...p, formal: e.target.value }))} className="rounded-2xl border border-purple-100 px-3 py-2 text-sm" />
                </div>
                <div className="grid grid-cols-2 gap-2">
                 <select
value={newItem.season}
onChange={(e) => setNewItem((p) => ({ ...p, season: e.target.value
}))}
className="rounded-2xl border border-purple-100 bg-white text-slate-800 px-3 py-2 text-sm">
                    <option value="all">all</option><option value="winter">winter</option><option value="spring">spring</option><option value="summer">summer</option><option value="autumn">autumn</option>
                  </select>
                  <input value={newItem.type} onChange={(e) => setNewItem((p) => ({ ...p, type: e.target.value }))} placeholder="Typ, z. B. dress/sneaker" className="rounded-2xl border border-purple-100 px-3 py-2 text-sm" />
                </div>
                <label className="flex items-center gap-2 rounded-2xl bg-purple-50 px-3 py-2 text-sm font-semibold text-purple-800"><input type="checkbox" checked={newItem.pinstripe} onChange={(e) => setNewItem((p) => ({ ...p, pinstripe: e.target.checked }))} /> Pinstripe</label>
                <button onClick={addInventoryItem} className="rounded-2xl bg-purple-100 px-4 py-2 text-sm font-black text-purple-800">Kleidungsstück hinzufügen</button>
              </div>
            </div>
          </Panel>
        </main>
      </div>
    </div>
