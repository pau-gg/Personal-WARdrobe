                <span className="text-xs font-semibold text-slate-500">Gespeicherte Looks: {favorites.length}</span>
                <select value={sortFavs} onChange={(e) => setSortFavs(e.target.value)} className="rounded-xl border border-purple-100 bg-white px-2 py-1 text-xs font-semibold">
                  <option value="new">nach neu</option>
                  <option value="score">nach Score</option>
                </select>
              </div>
              <div className="mt-3 max-h-56 space-y-2 overflow-auto pr-1">
                {sortedFavorites.map((fav) => <Favorite key={fav.id} favorite={fav} onLoad={() => setLook(fav.look)} onDelete={() => setFavorites((prev) => prev.filter((x) => x.id !== fav.id))} />)}
