  blazer: BASE_WARDROBE.blazers[3],
  pants: BASE_WARDROBE.pants[4],
  top: BASE_WARDROBE.tops[0],
  coat: BASE_WARDROBE.coats[0],
  shoes: BASE_WARDROBE.shoes[0],
  belt: BASE_WARDROBE.belts[1]
};

