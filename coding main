function getColor(name) {
  return COLORS[name] || COLORS[name?.replace(" Sneaker", "")] || COLORS[name?.replace(" Shirt", "")] || "#888";
}

function weightedPick(pool, scoreFn) {
  const scored = pool.map((x) => ({ item: x, weight: Math.max(1, scoreFn(x)) }));
  const total = scored.reduce((sum, x) => sum + x.weight, 0);
  let r = Math.random() * total;
  for (const s of scored) {
    r -= s.weight;
    if (r <= 0) return s.item;
  }
  return scored[0].item;
}

function scoreCandidate(outfit, key, candidate, mode, season, palette, note) {
  const a = analyzeLook(outfit, mode, season, palette, note);
  let value = a.score;
  if (candidate.off && (key === "coat" || key === "blazer")) value += season === "Summer" ? 12 : 0;
  if (mode === "Boss Look" && candidate.casual) value -= 10;
  return value;
}

function analyzeLook(look, mode, season, palette, note) {
  const randomPalette = palette === "Random";
  const pieces = Object.values(look).filter(Boolean);
  const worn = pieces.filter((p) => !p.off);
  const colors = worn.map((p) => p.color);
  const uniqueColors = [...new Set(colors)];  
  const accentColors = ["Berry", "Olive", "Red", "Green", "Purple", "Dark Purple", "Pink", "Rose", "Wine Red", "Medium Blue", "Light Blue"].filter((c) => colors.includes(c));
  const badColorCombos = [
["Red", "Green"],
["Berry", "Olive"],
["Pink", "Green"],
["Purple", "Olive"],
["Wine Red", "Green"]
];

const hasComplementaryCombo = badColorCombos.some(
([a, b]) => colors.includes(a) && colors.includes(b)
);
  const deepColors = ["Navy", "Navy Pinstripe", "Black", "Dark Grey", "Very Dark Blue", "Grey", "White", "Berry", "Purple", "Dark Purple"];
  const neutrals = ["Navy", "Navy Pinstripe", "Black", "Dark Grey", "Grey", "Light Grey", "White", "Eggshell", "Beige"];
  const formalAvg = worn.reduce((s, p) => s + (p.formal || 0), 0) / Math.max(1, worn.length);
  const hasSuit = !look.blazer.off && sameSuit(look.blazer, look.pants);
  const pinstripeSet = hasSuit && look.blazer.pinstripe && look.pants.pinstripe;
  const dressShoes = look.shoes.type === "dress";
  const blazerOn = !look.blazer.off;
  const coatOn = !look.coat.off;
  const casualCount = worn.filter((p) => p.casual).length;
  const beltMatch = beltScore(look.shoes, look.belt);
  const seasonFit = season === "Off" ? 8 : worn.reduce((s, p) => s + (p.seasons.includes("all") || p.seasons.includes(season.toLowerCase()) ? 10 : 4), 0) / Math.max(1, worn.length);

  let score = 58;
  score += Math.min(14, formalAvg * 1.15);
  score += worn.filter((p) => deepColors.includes(p.color)).length * 2.1;
  score += worn.filter((p) => neutrals.includes(p.color)).length * 1.2;
  score += beltMatch;
  score += seasonFit * 1.1;
  if (hasSuit) score += 10;
  if (pinstripeSet) score += 6;
  if (dressShoes) score += 7;
  if (blazerOn) score += 5;
  if (mode === "Boss Look") score += blazerOn && dressShoes ? 8 : -8;
  if (mode === "Elegant") score += dressShoes && accentColors.length <= 1 ? 6 : 0;
  if (mode === "Office Daily") score += formalAvg >= 7 && casualCount <= 1 ? 5 : -4;
  if (palette === "Quiet Luxury") score += colors.some((c) => ["Eggshell", "Beige", "Light Grey", "Grey", "Navy"].includes(c)) && accentColors.length <= 1 ? 5 : -2;
  if (palette === "Old Money") score += colors.some((c) => ["Navy", "Eggshell", "Beige", "Olive", "Grey"].includes(c)) ? 4 : 0;
  if (palette === "Clean Contrast") score += colors.includes("White") && colors.some((c) => ["Black", "Navy", "Dark Grey"].includes(c)) ? 5 : 0;

  if (accentColors.length > 2) score -= 14;
  if (uniqueColors.length === 1) score +=12;
  if (uniqueColors.length === 2) score +=8;
  if (uniqueColors.length > 2) score -=10;
  if (uniqueColors.length > 3) score -=20;
  if (hasComplementaryCombo) score -= 20;  
  if (colors.includes("Berry") && colors.includes("Olive") && (colors.includes("Red") || colors.includes("Pink"))) score -= 18;
  if (season === "Summer" && coatOn) score -= 15;
  if ((mode === "Boss Look" || mode === "Elegant") && casualCount > 1) score -= 12;
  if (/meeting|vortrag|termin|chef|wichtig/i.test(note)) score += blazerOn && dressShoes ? 5 : -4;
  if (/autofahrt|fahrt|lang/i.test(note)) score += look.shoes.type === "sneaker" || !coatOn ? 2 : 0;
  if (/heiß|heiss|warm|sommer/i.test(note)) score += look.top.category === "polo" && !coatOn ? 5 : -3;

  score = Math.max(35, Math.min(100, Math.round(score)));
 let label =
score >= 92 ? "Signature Look" :
score >= 84 ? "Very Harmonious" :
score >= 76 ? "Business Strong" :
score >= 66 ? "Solid" :
"Experimental";
if (hasComplementaryCombo) {
label = "Risky";
}

 
  const stats = {
    business: clamp10(Math.round(formalAvg + (blazerOn ? 1 : 0) + (dressShoes ? 1 : 0) - casualCount)),
    boss: clamp10(Math.round((formalAvg + (hasSuit ? 2 : 0) + (dressShoes ? 1 : 0) + (colors.includes("Black") ? 1 : 0)) / 1.25)),
    deepWinter: clamp10(Math.round((worn.filter((p) => deepColors.includes(p.color)).length / Math.max(1, worn.length)) * 10)),
    quietLuxury: clamp10(Math.round((worn.filter((p) => neutrals.includes(p.color)).length / Math.max(1, worn.length)) * 8 + (accentColors.length <= 1 ? 2 : 0)))
  };
  const main = dominantColor(colors);
  return {
    score,
    label,
    stats,
    colorEffect: colorPsychology(main, colors),
    perception: score >= 92 ? "Wirkt extrem souverän, fokussiert und hochwertig: ein echter Paulina-Signature-Look mit klarer Führungsenergie." : score >= 84 ? "Wirkt professionell, harmonisch und bewusst gestylt, ohne überladen zu sein." : score >= 76 ? "Wirkt business-tauglich und präsent, könnte aber noch ruhiger oder präziser werden." : "Wirkt tragbar, aber noch nicht maximal Paulina: einzelne Elemente konkurrieren miteinander.",
    makeup: makeupAdvice(colors, score),
    optimization: buildOptimization(look, accentColors, beltMatch, season, mode, score),
    toHundred: buildHundredTip(look, hasSuit, dressShoes, beltMatch, accentColors, season, mode)
  };
}

function sameSuit(blazer, pants) {
  if (blazer.off) return false;
  if (blazer.name === pants.name) return true;
  return blazer.color === pants.color && ["Black", "Navy", "Dark Grey", "Berry", "Olive", "Medium Blue"].includes(blazer.color);
}

function beltScore(shoes, belt) {
  if (belt.off) return 0;
  if (shoes.color === "Black" && belt.color === "Black") return 8;
  if (shoes.color === "Beige" && ["Beige", "Brown"].includes(belt.color)) return 6;
  if (shoes.color === "White" && ["White", "Beige"].includes(belt.color)) return 6;
  if (shoes.color === "Navy" && ["Black", "Beige"].includes(belt.color)) return 3;
  if (belt.color === "Brown" && !["Beige", "Olive", "Eggshell"].includes(shoes.color)) return -5;
  return -2;
}

function dominantColor(colors) {
  const priority = ["Navy Pinstripe", "Navy", "Black", "Dark Grey", "Grey", "White", "Berry", "Olive", "Beige", "Red", "Green", "Purple"];
  return priority.find((c) => colors.includes(c)) || colors[0] || "Navy";
}

function colorPsychology(main, colors) {
  const map = {
    Navy: "Navy vermittelt Kompetenz, Vertrauen und Ruhe. In Kombination mit klaren Kontrasten wirkt es sehr business-sicher.",
    "Navy Pinstripe": "Navy Pinstripe wirkt kompetent, klassisch und sehr führungsstark: ruhig, aber mit subtiler Autorität.",
    Black: "Black steht für Autorität, Fokus und Stärke. Der Look bekommt dadurch eine klare Boss-Energy.",
    "Dark Grey": "Dark Grey wirkt seriös, neutral und strukturiert. Es lässt Details hochwertig und kontrolliert wirken.",
    Grey: "Grey wirkt seriös, analytisch und modern. Perfekt, wenn der Look ruhig und professionell bleiben soll.",
    White: "White wirkt clean, klar und professionell. Es erhöht Frische und Kontrast.",
    Berry: "Berry wirkt individuell, edel und präsent. Ideal als kontrollierter Akzent.",
    Olive: "Olive wirkt ruhig, strategisch und grounded. Es bringt Tiefe, sollte aber klar kombiniert werden.",
    Beige: "Beige und Eggshell wirken soft, old money und quiet luxury. Besonders stark mit Navy, Black oder Grey.",
    Red: "Red wirkt präsent, mutig und auffällig. Am besten als bewusst gesetzter Fokuspunkt.",
    Green: "Green wirkt ruhig, wertig und natürlich. In Business-Looks besonders gut mit dunklen Neutralfarben.",
    Purple: "Purple wirkt kreativ, tief und luxuriös. Mit dunklen Basics sehr Paulina-kompatibel."
  };
  const extra = colors.includes("White") && colors.some((c) => ["Black", "Navy", "Dark Grey"].includes(c)) ? " Der Hell-Dunkel-Kontrast unterstützt Deep-Winter-Klarheit." : "";
  return (map[main] || map.Navy) + extra;
}

function makeupAdvice(colors, score) {
  const hasBerry = colors.includes("Berry") || colors.includes("Purple") || colors.includes("Red");
  const hasSoft = colors.includes("Beige") || colors.includes("Eggshell") || colors.includes("Rose");
  const lips = hasBerry ? "Lippen: kühles Berry, Rosenholz oder tiefes Mauve." : "Lippen: klares Nude-Rose, Soft Berry oder kühles Rot als Statement.";
  const blush = hasSoft ? "Blush: soft rose, sehr fein verblendet." : "Blush: kühles Rosé, sparsam und clean.";
  const eyes = score >= 84 ? "Augen: definierte Wimpern, dezenter Taupe/Grey-Liner, keine überladenen Farben." : "Augen: mit klarer Mascara und leichtem Lidstrich mehr Struktur geben.";
  return `${lips} ${blush} ${eyes}`;
}

function buildOptimization(look, accents, beltMatch, season, mode, score) {
  if (score >= 92) return "Nicht viel ändern: Silhouette, Kontrast und Business-Signal sind bereits sehr nah an Paulinas Ideal.";
  if (beltMatch < 0) return "Gürtel und Schuhe harmonisieren noch nicht optimal. Wähle bei schwarzen Schuhen bevorzugt den schwarzen Gürtel.";
  if (accents.length > 2) return "Reduziere Akzentfarben. Ein starker Akzent reicht, der Rest sollte Navy, Black, Grey, White oder Eggshell bleiben.";
  if (season === "Summer" && !look.coat.off) return "Für Summer den Mantel ausschalten. Das macht den Look leichter und glaubwürdiger.";
  if (mode === "Boss Look" && (look.blazer.off || look.shoes.type !== "dress")) return "Für Boss Look: Blazer aktivieren und schwarze Dress Shoes wählen.";
  return "Mehr Kontrast und eine ruhigere Farbachse würden den Look hochwertiger machen, z. B. Navy/Black/Grey mit White oder Eggshell.";
}

function buildHundredTip(look, hasSuit, dressShoes, beltMatch, accents, season, mode) {
  if (!hasSuit && mode === "Boss Look") return "Näher an 100 kommst du mit passendem Blazer-Hosen-Set, ideal Navy Pinstripe, Black oder Navy.";
  if (!dressShoes) return "Tausche Sneaker gegen Black Leather Loafer, Black Glossy Loafer oder Black Oxford für mehr Formalität.";
  if (beltMatch < 6) return "Schließe die Schuh-Gürtel-Achse: schwarze Schuhe plus schwarzer Gürtel ist die sauberste Business-Lösung.";
  if (accents.length > 1) return "Nutze maximal eine Akzentfarbe und halte die restlichen Teile neutral und dunkel.";
  if (season === "Winter" && look.coat.off) return "Im Winter kann ein schwarzer oder navy Mantel den Look noch kompletter und luxuriöser machen.";
  return "Für 100: klare dunkle Basis, hochwertige Kontraste, ruhige Accessoire-Achse und maximal ein bewusster Akzent.";
}

function clamp10(n) {
  return Math.max(0, Math.min(10, n));
}
