          <Panel title="Analyse / Score" subtitle="Personalized for Paulina: business, boss energy and Deep Winter.">
            <Analysis analysis={analysis} />
            <div className="mt-5 rounded-[1.5rem] bg-[#faf7f2] p-4 ring-1 ring-purple-100">
              <h3 className="font-black text-[#2a2040]">Favoriten</h3>
              <div className="mt-3 flex gap-2">
                <input value={favoriteName} onChange={(e) => setFavoriteName(e.target.value)} placeholder="Look-Name" className="min-w-0 flex-1 rounded-2xl border border-purple-100 bg-white px-3 py-2 text-sm outline-none focus:ring-4 focus:ring-purple-100" />
                <button onClick={saveFavorite} className="rounded-2xl bg-[#2a2040] px-4 py-2 text-sm font-bold text-white">Speichern</button>
