              <Category title="Schuhe" value={look.shoes.id} items={inventory.shoes} locked={locks.shoes} onLock={() => setLocks((p) => ({ ...p, shoes: !p.shoes }))} onRandom={() => randomCategory("shoes")} onChange={(id) => updateLook("shoes", id)} />
              <Category title="Gürtel" value={look.belt.id} items={inventory.belts} locked={locks.belt} onLock={() => setLocks((p) => ({ ...p, belt: !p.belt }))} onRandom={() => randomCategory("belt")} onChange={(id) => updateLook("belt", id)} />
            </div>
