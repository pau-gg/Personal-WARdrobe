  const analysis = useMemo(() => analyzeLook(look, styleMode, season, palette, note), [look, styleMode, season, palette, note]);
 

  function poolName(key) {
    return key === "blazer" ? "blazers" : key === "pants" ? "pants" : key === "top" ? "tops" : key === "coat" ? "coats" : key === "shoes" ? "shoes" : "belts";
  }

  function generateOutfit(forceAll = false) {
    const next = { ...look };
    ["blazer", "pants", "top", "coat", "shoes", "belt"].forEach((key) => {
      if (!forceAll && locks[key]) return;
      const pool = inventory[poolName(key)];
      next[key] = weightedPick(pool, (candidate) => scoreCandidate({ ...next, [key]: candidate }, key, candidate, styleMode, season, palette, note));
    });
    setLook(next);
  }

  function updateLook(key, id) {
    const found = inventory[poolName(key)].find((x) => x.id === id);
    if (found) setLook((prev) => ({ ...prev, [key]: found }));
  }

  function randomCategory(key) {
    const candidate = weightedPick(inventory[poolName(key)], (x) => scoreCandidate({ ...look, [key]: x }, key, x, styleMode, season, palette, note));
    setLook((prev) => ({ ...prev, [key]: candidate }));
  }

  function addInventoryItem() {
    if (!newItem.name.trim()) return;
    const group = newItem.group;
    const cat = group === "tops" ? "shirt" : group.slice(0, -1);
    const created = item(newItem.name.trim(), newItem.color.trim() || "Black", cat, Number(newItem.formal), [newItem.season || "all"], {
      pinstripe: newItem.pinstripe,
      type: newItem.type || undefined
    });
    setInventory((prev) => ({ ...prev, [group]: [...prev[group], created] }));
    setNewItem({ group: "tops", name: "", color: "Black", formal: 7, season: "all", pinstripe: false, type: "" });
  }

  function saveFavorite() {
    const name = favoriteName.trim() || `${analysis.label} ${favorites.length + 1}`;
    setFavorites((prev) => [{ id: Date.now(), name, look, score: analysis.score, label: analysis.label, created: Date.now() }, ...prev]);
    setFavoriteName("");
  }

